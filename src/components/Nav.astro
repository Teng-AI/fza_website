---
import { getCollection } from 'astro:content';

const conferences = (await getCollection('conferences')).sort((a, b) => b.data.year - a.data.year);
const { current = '' } = Astro.props;
---

<nav class="navigation">
  <div class="container">
    <a href="/" class="nav-logo" aria-label="Fuzhou America home">
      <img src="/images/logo.png" alt="Fuzhou America logo" />
    </a>
    <div class="nav-menu">
      <a href="/" class="nav-link" aria-current={current === 'home' ? 'page' : undefined}>Home</a>
      <a href="/about" class="nav-link" aria-current={current === 'about' ? 'page' : undefined}>About</a>
      <a href="/team" class="nav-link" aria-current={current === 'team' ? 'page' : undefined}>Team</a>
      <a href="/support-us" class="nav-link" aria-current={current === 'support-us' ? 'page' : undefined}>Support Us</a>
      <div class="nav-dropdown">
        <span class="nav-link" tabindex="0">Conference</span>
        <div class="nav-dropdown-list">
          {conferences.map((c) => <a href={`/conference/${c.data.year}`} class="nav-link">{c.data.year}</a>)}
        </div>
      </div>
      <a href="/contact" class="nav-link" aria-current={current === 'contact' ? 'page' : undefined}>Contact</a>
      <a href="https://bit.ly/sitebuttons" class="button">Join our Community</a>
    </div>
  </div>
</nav>
